classDiagram
    class Pet {
        +String name
        +String breed
        +List~String~ allergies
        +String notes
        +addActivity(activity) void
        +addNotes(note) void
        +updateInfo() void
    }

    class Owner {
        +String name
        +String contactInfo
        +String paymentInfo
        +addOwner() void
        +linkOwnerToPet(pet) void
        +addAdditionalPet(pet) void
        +contactOwner() void
        +takePayment() void
    }

    class Caretaker {
        +String name
        +String contactInfo
        +Boolean availability
        +addAssignment(pet) void
        +addSchedule(schedule) void
        +modifySchedule() void
        +contact() void
    }

    class Activity {
        +String type
        +String date
        +String time
        +String status
        +scheduleWalk() void
        +schedulePickup() void
    }

    class Schedule {
        +String date
        +addActivity(activity) void
        +getDailySchedule() List
        +getTasksForPet(pet) List
    }

    Owner "1" --> "*" Pet : owns
    Caretaker "*" --> "*" Pet : assigned to
    Caretaker "1" --> "1" Schedule : manages
    Schedule "1" *-- "*" Activity : contains
    Pet "1" --> "*" Activity : has
